{
  "manifest_version": 3,
  "name": "Groww Stock Tracker",
  "version": "1.4.2",
  "description": "Track and compare stock prices on Groww",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["*://groww.in/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://groww.in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
